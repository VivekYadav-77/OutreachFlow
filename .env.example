# ============================================================
#  EmailSender — Environment Variables Reference
#  Copy this file to server/.env and fill in real values.
#  Never commit server/.env to version control.
# ============================================================

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------

# PostgreSQL connection string.
# Format: postgres://<user>:<password>@<host>:<port>/<database>
# Required. The app will not start without this.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/email_sender

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------

# Port that the backend Express server will listen on.
# Optional. Defaults to 4000.
PORT=4000

# URL of the frontend. Used for CORS and OAuth redirect.
# Optional. Defaults to http://localhost:5173.
CLIENT_URL=http://localhost:5173

# Log verbosity. One of: trace, debug, info, warn, error, fatal, silent.
# Optional. Defaults to "info".
LOG_LEVEL=info

# ------------------------------------------------------------
# GOOGLE OAUTH 2.0 + GMAIL API
# Required to send emails through Gmail.
# Obtain from: https://console.cloud.google.com/
# See: docs/CONFIGURATION_GUIDE.md → "Google Cloud / Gmail API"
# ------------------------------------------------------------

# Your Google OAuth 2.0 Client ID.
GOOGLE_CLIENT_ID=your-google-client-id

# Your Google OAuth 2.0 Client Secret.
GOOGLE_CLIENT_SECRET=your-google-client-secret

# The OAuth callback URL registered in Google Cloud Console.
# Must match exactly. Do not change this in development.
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/callback

# ------------------------------------------------------------
# GOOGLE GEMINI AI  (Optional)
# Required only for the AI Cover Letter Generator feature.
# Obtain from: https://aistudio.google.com/app/apikey
# See: docs/CONFIGURATION_GUIDE.md → "Google Gemini AI"
# ------------------------------------------------------------

# Your Gemini API key. Leave blank to disable the Cover Letter Generator.
GEMINI_API_KEY=your-gemini-api-key-here

# The Gemini model to use for cover letter generation.
# Optional. Defaults to "gemini-3.1-flash-lite".
# See available models: https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL_NAME=gemini-3.1-flash-lite
